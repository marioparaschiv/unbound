{
	"name": "unbound",
	"private": true,
	"workspaces": {
		"packages": [
			"packages/client",
			"packages/debugger",
			"packages/types",
			"packages/api",
			"packages/plugin-test",
			"packages/utils",
			"packages/logger",
			"packages/client/scripts/build",
			"packages/client/scripts/serve"
		],
		"catalog": {
			"typescript": "^5.9.3",
			"possess": "^1.0.8",
			"@types/bun": "latest"
		},
		"catalogs": {
			"react": {
				"@types/react": "^19.2.7",
				"react": "^19.2.3",
				"react-native": "^0.83.0"
			}
		}
	},
	"scripts": {
		"generate-sdk": "bun scripts/generate-plugin-sdk.ts",
		"lint": "oxlint --config .oxlintrc.json apps packages",
