{
	"name": "unbound",
	"private": true,
	"workspaces": {
		"packages": [
			"packages/client",
			"packages/debugger",
			"packages/types",
			"packages/api",
			"apps/sdk-generator",
			"packages/plugin-test",
			"packages/utils",
			"packages/logger",
			"packages/client/scripts/build",
			"packages/client/scripts/serve",
			"packages/client/scripts/dev"
		],
		"catalog": {
			"typescript": "^5.9.3",
			"possess": "^1.1.0",
			"@types/bun": "latest"
		},
		"catalogs": {
			"react": {
				"@types/react": "^19.2.7",
				"react": "^19.2.3",
				"react-native": "^0.83.0"
			}
		}
	},
	"scripts": {
		"prepare": "lefthook install --reset-hooks-path",
		"generate-sdk": "bun apps/sdk-generator/index.ts",
		"lint": "oxlint --config .oxlintrc.json apps packages",
		"lint:fix": "oxlint --config .oxlintrc.json --fix-dangerously apps packages",
		"fmt": "oxfmt --config .oxfmtrc.json apps packages",
		"fmt:check": "oxfmt --config .oxfmtrc.json --check apps packages"
	},
	"dependencies": {
		"@typescript/native-preview": "7.0.0-dev.20260623.1",
		"eslint-plugin-perfectionist": "^5.9.1"
	},
	"devDependencies": {
		"@ast-grep/cli": "^0.44.0",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-angular": "^21.0.2",
		"dts-bundle-generator": "^9.5.1",
		"lefthook": "^2.1.9",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"ts-morph": "^28.0.0"
	},
	"trustedDependencies": [
		"@ast-grep/cli",
		"lefthook"
	]
}
