		"fmt": "oxfmt --config .oxfmtrc.json apps packages",
		"fmt:check": "oxfmt --config .oxfmtrc.json --check apps packages"
	},
	"devDependencies": {
		"dts-bundle-generator": "^9.5.1",
		"oxfmt": "^0.26.0",
		"oxlint": "^1.41.0",
		"oxlint-tsgolint": "^0.11.1",
		"ts-morph": "^27.0.2"
	},
	"dependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260123.3",
		"eslint-plugin-perfectionist": "^5.4.0"
