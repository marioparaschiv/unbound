		"./*": {
			"types": "./_unbound/*.d.ts",
			"default": "./unbound/*"
		}
	},
	"dependencies": {
		"possess": "^1.0.4",
		"superagent": "^10.2.3",
		"type-fest": "^4.33.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.0",
		"@types/react": "^19.2.2",
		"@types/react-native": "^0.73.0"
	},
	"peerDependencies": {
		"typescript": "^5",
		"react": ">=18",
		"@types/react": ">=18",
		"react-native": ">=0.73",
		"@types/react-native": ">=0.73"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": false
		},
		"@types/react": {
			"optional": false
		},
		"react-native": {
			"optional": false
		},
		"@types/react-native": {
			"optional": false
		}
	}
