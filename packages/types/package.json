{
	"name": "@unbound-app/types",
	"version": "1.0.0",
	"type": "module",
	"main": "",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.d.ts"
		},
		"./discord/*": {
			"types": "./discord/*.d.ts",
			"default": "./discord/*"
